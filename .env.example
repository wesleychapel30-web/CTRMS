# Core Django settings
DEBUG=True
SECRET_KEY=change-this-secret-key
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Frontend / API origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000,http://127.0.0.1:8000
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000,http://127.0.0.1:8000
DEV_CORS_ORIGINS=
DEV_CSRF_TRUSTED_ORIGINS=

# Database
# Leave DATABASE_URL unset to use the default local SQLite database.
# DATABASE_URL=postgres://ctrms:change-this-db-password@localhost:5432/ctrms

# Email
# For local development you can keep the console backend.
# For production switch to django.core.mail.backends.smtp.EmailBackend.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@example.com

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Security
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=3600
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
ENCRYPTION_ENABLED=True

# Media serving
SERVE_MEDIA=True
# Set this to your persistent uploads directory in production, for example:
# MEDIA_ROOT=/var/data/media
MEDIA_ROOT=
# Optional helper if you prefer pointing to the disk mount and letting the app append /media
RENDER_DISK_PATH=

# Gunicorn / container runtime
PORT=8000
WEB_CONCURRENCY=3
GUNICORN_TIMEOUT=60

# Bootstrap branding and organization defaults
CTRMS_SITE_NAME=CTRMS
CTRMS_ORG_NAME=CTRMS
CTRMS_ORG_EMAIL=support@example.com
CTRMS_SUPPORT_EMAIL=support@example.com
CTRMS_ORG_PHONE=
CTRMS_ORG_ADDRESS=
CTRMS_ORG_WEBSITE=
CTRMS_PRIMARY_COLOR="#2563eb"
CTRMS_SECONDARY_COLOR="#0ea5e9"

# Bootstrap users
CTRMS_ADMIN_USERNAME=admin
CTRMS_ADMIN_EMAIL=admin@example.com
CTRMS_ADMIN_PASSWORD=change-this-admin-password
CTRMS_DIRECTOR_USERNAME=director
CTRMS_DIRECTOR_EMAIL=director@example.com
CTRMS_DIRECTOR_PASSWORD=change-this-director-password

# Self-hosted production compose helpers
POSTGRES_DB=ctrms
POSTGRES_USER=ctrms
POSTGRES_PASSWORD=change-this-postgres-password
APP_PORT=8000
CTRMS_IMAGE=ghcr.io/wesleychapel30-web/ctrms:latest
